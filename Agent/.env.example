# =============================================================================
# AlphaTrade AI Agent (Flask + bnbagent SDK) — environment.
# Copy to Agent/.env and fill in. All values are server-only; never exposed.
# =============================================================================

# --- Groq AI decision engine -------------------------------------------------
# Without it, /api/agent/decide returns a clearly labelled deterministic demo.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- BNB AI Agent SDK (bnbagent) : ERC-8004 identity -------------------------
BNB_NETWORK=bsc-testnet
# Encrypts the wallet keystore at ~/.bnbagent/wallets/. Required to register.
WALLET_PASSWORD=change-me-to-a-strong-password
# 0x-prefixed key, FUNDED with testnet BNB. FIRST RUN ONLY — after the first
# successful register the key is encrypted on disk; then remove it from here.
PRIVATE_KEY=
# On-chain identity metadata used by register_agent.py / /api/bnb/register.
AGENT_NAME=alphatrade-agent
AGENT_DESCRIPTION=AlphaTrade autonomous trading agent on BNB Chain
AGENT_ENDPOINT_URL=http://localhost:8003/erc8183/status

# --- ERC-8183 job server (only if you run agent_server.py) -------------------
ERC8183_AGENT_URL=http://localhost:8003/erc8183     # required by LocalStorageProvider
ERC8183_SERVICE_PRICE=1000000000000000000           # 1 token (18 decimals)
ERC8183_PORT=8003
# STORAGE_API_KEY=                                   # IPFS pinning JWT (IPFSStorageProvider)
# Optional knobs:
# ERC8183_FUNDED_POLL_INTERVAL=30
# ERC8183_NEGOTIATE_RATE_LIMIT=120
# ERC8183_NEGOTIATE_RATE_WINDOW=60
# ERC8183_MAX_RESPONSE_BYTES=5242880
# ERC8183_MAX_METADATA_BYTES=262144

# --- Flask decision server ---------------------------------------------------
HOST=127.0.0.1
PORT=5000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
