# =============================================================================
# AlphaTrade — environment configuration
#
# This is a Vite / TanStack Start app. Only variables prefixed with VITE_ are
# exposed to the browser bundle. Everything else is server-only and is read
# exclusively inside server routes (e.g. /api/agent/decide) and service stubs.
#
# Copy to `.env` and fill in. Never commit `.env`.
# =============================================================================

# ---------- PUBLIC (browser-safe, VITE_ prefix) ----------
# Defaults target BSC TESTNET (chain 97). To run on mainnet, set VITE_CHAIN_ID=56
# and the matching RPC / explorer / contract.
VITE_CHAIN_ID=97
VITE_BSC_RPC_URL=https://bsc-testnet-rpc.publicnode.com
# Deploy CompetitionRegistry to testnet (blockchain/ -> npm run deploy:testnet)
# and paste the printed address here. No default — the mainnet address won't work.
VITE_COMPETITION_CONTRACT=
VITE_WALLETCONNECT_PROJECT_ID=

# =============================================================================
# !!  SERVER-ONLY — DO NOT EXPOSE TO BROWSER  !!
# Read only inside server functions / server routes. NEVER add a VITE_ (or any
# public) prefix to these — doing so ships the secret to every visitor.
# =============================================================================

# CoinMarketCap AI Agent Hub (signals, paid per-call via x402)
CMC_AGENT_API_KEY=
CMC_AGENT_BASE_URL=https://pro-api.coinmarketcap.com/agent/v1
# Base used by /api/signals for the (real) Fear & Greed endpoint.
CMC_API_URL=https://pro-api.coinmarketcap.com

# BscScan API key — powers /api/chain/txs (real on-chain trade history).
# Free key from https://bscscan.com/myapikey (same key works for testnet).
BSCSCAN_API_KEY=
BSCSCAN_API_URL=https://api-testnet.bscscan.com/api

# x402 pay-per-request facilitator
X402_FACILITATOR_URL=https://x402.example/facilitator

# Trust Wallet Agent Kit (TWAK) — THE ONLY execution/signing layer. Signing is
# server-side; the HMAC secret NEVER reaches the browser (never add a VITE_ prefix).
# Credentials come from https://portal.trustwallet.com.
# Auth: HMAC-SHA256 over METHOD;PATH;QUERY;ACCESS_ID;NONCE;DATE (semicolon-separated).
# Header format: Authorization: HMAC-SHA256 Signature=<base64>
# Date format: RFC 1123 / HTTP-date in GMT.
TWAK_API_URL=https://tws.trustwallet.com
TW_ACCESS_ID=
TW_HMAC_SECRET=
# Agent wallet whose balances/history the dashboard reads (competition wallet address).
# SLIP44 coin id: 60 = EVM (Ethereum / BNB Smart Chain).
TWAK_AGENT_ADDRESS=
TWAK_COIN=60
# Confirmed swap paths from portal.trustwallet.com API reference:
#   Route/quote:  POST /amber-api/v1/route       (wired in twakService.ts)
#   Execute step: POST /amber-api/v1/route/step   (wired in twakService.ts)
# Competition registration path — only set this if Trust Wallet provides a signed path.
# If unset, the UI falls back to direct on-chain wallet signing via wagmi.
# TWAK_REGISTER_PATH=

# Python Agent server URL — the TanStack frontend proxies /api/agent/decide here.
# Start the Python Agent with: cd Agent && python wsgi.py   (default port 5000)
AGENT_API_URL=http://localhost:5000

# BNB AI Agent SDK / on-chain reads (testnet by default)
BNB_AGENT_RPC=https://bsc-testnet-rpc.publicnode.com
BNB_AGENT_KEY=

# Groq AI decision engine. Server-only. Never expose, never prefix with VITE_.
# AlphaTrade calls Groq only from /api/agent/decide.
GROQ_API_KEY=

# Server-only. Never expose. Signing happens via TWAK; this is a hot-wallet
# fallback used only by the on-chain registration / deploy tooling.
AGENT_PRIVATE_KEY=
