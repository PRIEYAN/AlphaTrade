# =============================================================================
# AlphaTrade contracts (Hardhat) — environment
# Copy to blockchain/.env and fill in. NEVER commit a real private key.
# =============================================================================

# Deployer / agent key. Used to sign the deploy + registration transactions.
# Self-custodial: this key signs locally; it is never sent anywhere.
AGENT_PRIVATE_KEY=

# RPC endpoints
BSC_RPC_URL=https://bsc-dataseed.binance.org
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545

# BscScan API key (for `hardhat verify`)
BSCSCAN_API_KEY=

# Unix timestamp (seconds) when the trading window opens. Registrations after
# this time are rejected on-chain. If unset, deploy defaults to now + 7 days.
REGISTRATION_DEADLINE=
