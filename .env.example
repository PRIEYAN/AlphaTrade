# ===== PUBLIC (browser-safe) =====
NEXT_PUBLIC_BSC_RPC_URL=https://bsc-dataseed.binance.org
NEXT_PUBLIC_CHAIN_ID=56
NEXT_PUBLIC_COMPETITION_CONTRACT=0x212c61b9b72c95d95bf29cf032f5e5635629aed5
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ===== SERVER-ONLY — DO NOT EXPOSE TO BROWSER =====
# These are read only inside server functions / server routes.
# NEVER prefix any of these with NEXT_PUBLIC_ or VITE_.

CMC_AGENT_API_KEY=
CMC_AGENT_BASE_URL=https://pro-api.coinmarketcap.com/agent/v1
# Base used by /api/signals for the (real) Fear & Greed endpoint.
CMC_API_URL=https://pro-api.coinmarketcap.com

# BscScan API key — powers /api/chain/txs (real on-chain trade history).
# Free key from https://bscscan.com/myapikey. Without it the Activity log is empty.
BSCSCAN_API_KEY=
BSCSCAN_API_URL=https://api.bscscan.com/api

X402_FACILITATOR_URL=https://x402.example/facilitator

# Trust Wallet Agent Kit (TWAK) — THE ONLY execution/signing layer. Signing is
# server-side; the HMAC secret NEVER reaches the browser (never add a VITE_ prefix).
# Credentials come from https://portal.trustwallet.com. Every request is signed
# with HMAC-SHA256 over METHOD+PATH+QUERY+ACCESS_ID+NONCE+DATE (see twClient.ts).
TWAK_API_URL=https://tws.trustwallet.com
TW_ACCESS_ID=
TW_HMAC_SECRET=
# Agent wallet whose balances/history the dashboard reads, plus its SLIP44 coin
# id (60 = EVM, i.e. Ethereum / BNB Smart Chain). Set to your competition wallet.
TWAK_AGENT_ADDRESS=
TWAK_COIN=60
# Optional path overrides — set ONLY once confirmed against the portal API
# reference or `twak --verbose`. Swap/registration REST paths are not yet
# documented publicly, so the code leaves them off by default.
# TWAK_SWAP_QUOTE_PATH=/v1/swap/quote
# TWAK_SWAP_EXECUTE_PATH=/v1/swap/execute
# TWAK_REGISTER_PATH=

BNB_AGENT_RPC=https://bsc-dataseed.binance.org
BNB_AGENT_KEY=

# Server-only. Never expose. AlphaTrade calls Groq from /api/agent/decide.
GROQ_API_KEY=

# Server-only. Never expose. Signing happens via TWAK; this is a hot-wallet fallback only.
AGENT_PRIVATE_KEY=
