{
  "services": [
    {
      "type": "web",
      "name": "alphatrade-agent",
      "env": "python",
      "region": "oregon",
      "buildCommand": "pip install -r requirements.txt",
      "startCommand": "gunicorn wsgi:app -w 4 -b 0.0.0.0:8000",
      "envVars": [
        { "key": "FLASK_ENV", "value": "production", "secure": false }
      ],
      "plan": "starter"
    }
  ]
}
