# =============================================================================
# AlphaTrade — environment configuration
#
# This is a Vite / TanStack Start app. Only variables prefixed with VITE_ are
# exposed to the browser bundle. Everything else is server-only and is read
# exclusively inside server routes (e.g. /api/agent/decide) and service stubs.
#
# Copy to `.env` and fill in. Never commit `.env`.
# =============================================================================

# ---------- PUBLIC (browser-safe, VITE_ prefix) ----------
VITE_BSC_RPC_URL=https://bsc-dataseed.binance.org
VITE_CHAIN_ID=56
VITE_COMPETITION_CONTRACT=0x212c61b9b72c95d95bf29cf032f5e5635629aed5
VITE_WALLETCONNECT_PROJECT_ID=

# =============================================================================
# !!  SERVER-ONLY — DO NOT EXPOSE TO BROWSER  !!
# Read only inside server functions / server routes. NEVER add a VITE_ (or any
# public) prefix to these — doing so ships the secret to every visitor.
# =============================================================================

# CoinMarketCap AI Agent Hub (signals, paid per-call via x402)
CMC_AGENT_API_KEY=
CMC_AGENT_BASE_URL=https://pro-api.coinmarketcap.com/agent/v1

# x402 pay-per-request facilitator
X402_FACILITATOR_URL=https://x402.example/facilitator

# Trust Wallet Agent Kit — THE ONLY execution/signing layer. Signing is
# server-side; private keys never reach the browser.
TWAK_API_URL=https://api.trustwallet.com/agent
TWAK_API_KEY=

# BNB AI Agent SDK
BNB_AGENT_RPC=https://bsc-dataseed.binance.org
BNB_AGENT_KEY=

# Groq AI decision engine. Server-only. Never expose, never prefix with VITE_.
# AlphaTrade calls Groq only from /api/agent/decide.
GROQ_API_KEY=

# Server-only. Never expose. Signing happens via TWAK; this is a hot-wallet
# fallback used only by the on-chain registration / deploy tooling.
AGENT_PRIVATE_KEY=
