# =============================================================================
# AlphaTrade AI Agent (Flask) — environment. Copy to Agent/.env and fill in.
# All values are server-only; never exposed to a browser.
# =============================================================================

# Groq AI decision engine. Without it, /api/agent/decide returns a clearly
# labelled deterministic demo decision (pipeline still works).
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# BNB Smart Chain (on-chain agent). Public RPC works with no key.
BNB_AGENT_RPC=https://bsc-dataseed.binance.org
CHAIN_ID=56

# Server
HOST=127.0.0.1
PORT=5000

# CORS — origins of the web app allowed to call this backend.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
